# Add inputs and outputs from these tool invocations to the build variables 
SECONDARY_FLASH += \
control_motor.hex \

SECONDARY_LIST += \
control_motor.lst \

SECONDARY_SIZE += \
control_motor.siz \


# All Target
all: 
	$(MAKE) --no-print-directory main-build 

main-build: control_motor.elf secondary-outputs

# Tool invocations
control_motor.elf: $(OBJS) $(USER_OBJS_ESCAPE)
	@	riscv-none-embed-gcc -march=rv32imacxw -mabi=ilp32 -msmall-data-limit=8 -msave-restore -fmax-errors=20 -Os -fmessage-length=0 -fsigned-char -ffunction-sections -fdata-sections -fno-common -Wunused -Wuninitialized -g -T "c:\beifen\ESP32_P4_EV\Embedded_competition\CH32\Ld\Link.ld" -nostartfiles -Xlinker --gc-sections -Wl,-Map,"control_motor.map" --specs=nano.specs --specs=nosys.specs -o "control_motor.elf" $(OBJS) $(LIBS)
control_motor.hex: control_motor.elf
	@	riscv-none-embed-objcopy -O ihex "control_motor.elf" "control_motor.hex"
control_motor.lst: control_motor.elf
	@	riscv-none-embed-objdump --all-headers --demangle --disassemble -M xw "control_motor.elf" > "control_motor.lst"
control_motor.siz: control_motor.elf
	riscv-none-embed-size --format=berkeley "control_motor.elf"

# Other Targets
clean:
	-$(RM) $(DIR_OBJS) $(SECONDARY_FLASH)$(SECONDARY_LIST)$(SECONDARY_SIZE) control_motor.elf
	-$(RM) $(DIR_EXPANDS) $(CALLGRAPH_DOT)
	-$(RM) $(DIR_DEPS)
secondary-outputs: $(SECONDARY_FLASH) $(SECONDARY_LIST) $(SECONDARY_SIZE)

.PHONY: all clean dependents

