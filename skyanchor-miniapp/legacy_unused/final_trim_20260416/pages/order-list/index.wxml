<view class="page">
  <view class="hero">
    <view class="title">配送端订单列表</view>
    <view class="subtitle">通过配送员 ID 拉取已创建的订单，查看当前的状态流转。</view>
  </view>

  <view class="card">
    <view class="field">
      <text class="field-label">配送员 ID</text>
      <input class="input" value="{{senderId}}" bindinput="handleInput" />
    </view>

    <button class="primary-btn" loading="{{loading}}" bindtap="fetchOrders">刷新订单</button>
  </view>

  <view class="card">
    <view class="section-title">订单列表</view>
    <block wx:if="{{orders.length}}">
      <block wx:for="{{orders}}" wx:key="order_id">
        <view class="list-item" data-order-id="{{item.order_id}}" bindtap="openDetail">
          <view class="item-title">{{item.order_id}}</view>
          <view class="item-subtitle">目标 ID：{{item.target_id}} | 设备：{{item.device_name}}</view>
          <view class="item-meta">收货人：{{item.receiver_id}}</view>
          <view class="status-badge status-{{item.status}}">{{item.status_text}}</view>
        </view>
      </block>
    </block>
    <view wx:else class="empty">暂无订单</view>
  </view>
</view>
