<view class="page">
  <view class="hero">
    <view class="title">配送系统</view>
    <view class="subtitle">先设置默认的配送员和收货人标识，再进入你要联调的页面。</view>
  </view>

  <view class="card">
    <view class="section-title">默认身份</view>

    <view class="field">
      <text class="field-label">配送员 ID</text>
      <input class="input" value="{{senderId}}" data-key="senderId" bindinput="handleInput" />
    </view>

    <view class="field">
      <text class="field-label">收货人 ID</text>
      <input class="input" value="{{receiverId}}" data-key="receiverId" bindinput="handleInput" />
    </view>

    <button class="ghost-btn" bindtap="saveDefaults">保存默认身份</button>
  </view>

  <view class="card">
    <view class="section-title">进入页面</view>
    <view class="button-row">
      <button class="primary-btn" bindtap="openCreateOrder">创建订单</button>
      <button class="ghost-btn" bindtap="openOrderList">配送端订单</button>
      <button class="ghost-btn" bindtap="openNotifications">收货端通知</button>
    </view>
  </view>
</view>
