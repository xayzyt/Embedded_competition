<view class="page">
  <view class="hero">
    <view class="title">订单详情</view>
    <view class="subtitle">这里既能看真实订单状态，也能用调试接口模拟送达、失败和动作中。</view>
  </view>

  <view class="card" wx:if="{{order}}">
    <view class="section-title">{{order.order_id}}</view>
    <view class="kv">
      <text class="kv-key">状态</text>
      <text class="kv-value">{{order.status_text}}</text>
    </view>
    <view class="kv">
      <text class="kv-key">目标 ID</text>
      <text class="kv-value">{{order.target_id}}</text>
    </view>
    <view class="kv">
      <text class="kv-key">设备</text>
      <text class="kv-value">{{order.device_name}}</text>
    </view>
    <view class="kv">
      <text class="kv-key">收货人</text>
      <text class="kv-value">{{order.receiver_id}}</text>
    </view>
    <view class="kv">
      <text class="kv-key">备注</text>
      <text class="kv-value">{{order.note}}</text>
    </view>
  </view>

  <view class="card">
    <view class="section-title">操作</view>
    <view class="button-row">
      <button class="primary-btn" loading="{{loading}}" bindtap="fetchDetail">刷新</button>
      <button class="ghost-btn" bindtap="startOrder">开始配送</button>
      <button class="warn-btn" bindtap="cancelOrder">取消订单</button>
    </view>
  </view>

  <view class="card">
    <view class="section-title">调试模拟</view>
    <view class="button-row">
      <button class="ghost-btn" bindtap="mockActing">模拟 acting</button>
      <button class="primary-btn" bindtap="mockDelivered">模拟 delivered</button>
      <button class="warn-btn" bindtap="mockFailed">模拟 failed</button>
    </view>
  </view>

  <view class="card">
    <view class="section-title">事件记录</view>
    <block wx:if="{{events.length}}">
      <block wx:for="{{events}}" wx:key="id">
        <view class="list-item">
          <view class="item-title">{{item.event_type}}</view>
          <view class="item-subtitle">{{item.event_data}}</view>
          <view class="item-meta">{{item.created_at}}</view>
        </view>
      </block>
    </block>
    <view wx:else class="empty">暂无事件记录</view>
  </view>
</view>
