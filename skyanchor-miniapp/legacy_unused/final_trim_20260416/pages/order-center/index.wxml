<view class="page">
  <view class="hero">
    <view class="title">订单详情</view>
    <view class="subtitle">这里可以查看真实订单状态，也可以通过调试按钮模拟设备状态流转。</view>
  </view>

  <view class="service-banner status-{{serviceState}}">
    {{serviceMessage}}
  </view>

  <view class="card" wx:if="{{loadError}}">
    <view class="section-title">订单状态</view>
    <view class="empty">{{loadError}}</view>
    <view class="button-row">
      <button class="primary-btn" loading="{{loading}}" bindtap="fetchDetail">重新加载</button>
    </view>
  </view>

  <view class="card" wx:elif="{{loading && !order}}">
    <view class="section-title">订单状态</view>
    <view class="empty">正在加载订单详情...</view>
  </view>

  <view class="card" wx:if="{{order}}">
    <view class="section-title">{{order.order_id}}</view>
    <view class="section-caption">这里展示当前订单的真实业务信息，适合作为答辩时的主状态页。</view>
    <view class="kv">
      <text class="kv-key">状态</text>
      <text class="kv-value">{{order.status_text}}</text>
    </view>
    <view class="kv">
      <text class="kv-key">目标 ID</text>
      <text class="kv-value">{{order.target_id}}</text>
    </view>
    <view class="kv">
      <text class="kv-key">设备</text>
      <text class="kv-value">{{order.device_name}}</text>
    </view>
    <view class="kv">
      <text class="kv-key">收货人</text>
      <text class="kv-value">{{order.receiver_id}}</text>
    </view>
    <view class="kv">
      <text class="kv-key">备注</text>
      <text class="kv-value">{{order.note_text}}</text>
    </view>
    <view class="button-row detail-action-row {{isReceiverView ? 'single-action-row' : ''}}">
      <button class="ghost-btn" loading="{{loading}}" bindtap="fetchDetail">刷新</button>
      <button wx:if="{{!isReceiverView}}" class="primary-btn" disabled="{{!order.can_start}}" bindtap="startOrder">开始配送</button>
      <button wx:if="{{!isReceiverView}}" class="warn-btn" disabled="{{!order.can_cancel}}" bindtap="cancelOrder">取消订单</button>
    </view>
  </view>

