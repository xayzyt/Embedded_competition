page {
  background: #eef3fb;
  color: #172033;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

button::after {
  border: none;
}

.page {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 28rpx 24rpx 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.app-page {
  overflow: hidden;
  background-color: #f2f6fb;
  background:
    radial-gradient(circle at 10% -6%, rgba(96, 165, 250, 0.22), transparent 34%),
    radial-gradient(circle at 96% 18%, rgba(34, 197, 94, 0.12), transparent 28%),
    linear-gradient(180deg, #eef5ff 0%, #f7faff 42%, #f2f6fb 100%);
}

.app-page::before,
.app-page::after {
  content: "";
  position: absolute;
  pointer-events: none;
  border-radius: 999rpx;
}

.app-page::before {
  top: -130rpx;
  left: -150rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(37, 99, 235, 0.08);
}

.app-page::after {
  right: -170rpx;
  bottom: 240rpx;
  width: 360rpx;
  height: 360rpx;
  background: rgba(14, 165, 233, 0.06);
}

.app-page > .hero,
.app-page > .service-banner,
.app-page > .card,
.app-page > .page-footnote {
  position: relative;
  z-index: 1;
}

.page-footnote {
  margin-top: auto;
  padding-top: 30rpx;
  text-align: center;
  color: #8ba0b7;
  font-size: 21rpx;
  line-height: 1.55;
}

.page-footnote-team {
  margin-bottom: 4rpx;
  font-size: 20rpx;
  color: #91a2b7;
  letter-spacing: 0;
}

.hero {
  margin-bottom: 20rpx;
}

.page-hero {
  padding-top: 0;
}

.hero-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.hero-card {
  padding: 24rpx;
  border: 1rpx solid rgba(191, 219, 254, 0.72);
  border-radius: 16rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.94) 0%, rgba(239, 246, 255, 0.96) 100%);
  box-shadow: 0 18rpx 42rpx rgba(37, 99, 235, 0.1);
}

.hero-card .small-btn {
  background: rgba(255, 255, 255, 0.76);
  color: #1e40af;
  box-shadow: none;
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  width: 100%;
}

.hero-stat {
  min-width: 92rpx;
  padding: 11rpx 16rpx;
  border: 1rpx solid rgba(147, 197, 253, 0.42);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
  text-align: center;
}

.hero-stat-value,
.hero-stat-label {
  display: block;
  line-height: 1.2;
}

.hero-stat-value {
  color: #1d4ed8;
  font-size: 27rpx;
  font-weight: 900;
}

.hero-stat-label {
  margin-top: 4rpx;
  color: #64748b;
  font-size: 19rpx;
  font-weight: 800;
}

.hero-stat-warm .hero-stat-value {
  color: #d97706;
}

.dispatch-hero {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.dispatch-hero .hero-copy {
  width: 100%;
}

.dispatch-hero .title,
.dispatch-hero .hero-meta {
  white-space: nowrap;
}

.dispatch-hero .hero-actions {
  width: 100%;
}

.dispatch-hero .hero-actions .small-btn {
  flex: 1;
  min-width: 0;
}

.title {
  color: #172033;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.18;
  margin-bottom: 10rpx;
}

.hero-line .title {
  margin-bottom: 0;
}

.hero-meta {
  margin-top: 7rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.35;
}

.subtitle {
  color: #607086;
  line-height: 1.5;
}

.card {
  background: #ffffff;
  border: 1rpx solid rgba(226, 232, 240, 0.92);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.075);
  margin-bottom: 20rpx;
}

.profile-card {
  padding-bottom: 26rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
}

.list-card {
  padding-top: 22rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.section-title {
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
  margin-bottom: 16rpx;
}

.section-head .section-title {
  margin-bottom: 0;
}

.count-pill {
  flex-shrink: 0;
  min-width: 56rpx;
  padding: 7rpx 15rpx;
  border-radius: 999rpx;
  background: #eaf2ff;
  color: #2454c6;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.25;
  text-align: center;
}

.field {
  margin-bottom: 18rpx;
}

.field-label {
  display: block;
  color: #475569;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  background: #fbfdff;
  border: 2rpx solid #d8e4f2;
  border-radius: 14rpx;
  box-sizing: border-box;
  color: #172033;
}

.input {
  display: block;
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.button-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.button-row.compact {
  gap: 12rpx;
}

.button-row.compact .primary-btn,
.button-row.compact .ghost-btn,
.button-row.compact .warn-btn {
  flex: 1;
  min-width: 0;
}

.primary-btn,
.ghost-btn,
.warn-btn,
.safe-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  margin: 0;
  border: none;
  border-radius: 14rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.2;
}

.primary-btn {
  background: linear-gradient(135deg, #3478ff 0%, #1d4ed8 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(37, 99, 235, 0.24);
}

.ghost-btn {
  background: #edf3fb;
  color: #243044;
}

.warn-btn {
  background: #dc2626;
  color: #ffffff;
}

.safe-btn {
  background: #0f766e;
  color: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(15, 118, 110, 0.18);
}

.primary-btn[disabled],
.ghost-btn[disabled],
.warn-btn[disabled],
.safe-btn[disabled] {
  opacity: 0.56;
}

.small-btn {
  min-width: 136rpx;
  min-height: 64rpx;
  height: 64rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  line-height: 1;
}

.refresh-btn::before {
  content: "";
  width: 18rpx;
  height: 18rpx;
  margin-right: 8rpx;
  border: 3rpx solid currentColor;
  border-left-color: transparent;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.diagnostic-btn {
  min-width: 112rpx;
}

.detail-action-row {
  margin-top: 24rpx;
  flex-wrap: nowrap;
}

.detail-action-row .primary-btn,
.detail-action-row .ghost-btn,
.detail-action-row .warn-btn {
  flex: 1;
  min-width: 0;
  padding: 0 12rpx;
  font-size: 26rpx;
}

.manual-action-row {
  margin-top: 16rpx;
}

.manual-action-row .safe-btn {
  flex: 1;
}

.single-action-row .ghost-btn {
  flex: 1;
}

.service-banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid transparent;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.045);
}

.service-dot {
  flex-shrink: 0;
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: currentColor;
  box-shadow: 0 0 0 6rpx rgba(255, 255, 255, 0.55);
}

.service-message {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.service-detail-btn {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: currentColor;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.25;
}

.service-banner.status-ready {
  background: linear-gradient(135deg, #dcfce7 0%, #ecfdf5 100%);
  border-color: #a7f3d0;
  color: #166534;
}

.service-banner.status-backend-only {
  background: linear-gradient(135deg, #fff7ed 0%, #fffbeb 100%);
  border-color: #fed7aa;
  color: #9a3412;
}

.service-banner.status-offline,
.service-banner.status-weather-blocked {
  background: linear-gradient(135deg, #fee2e2 0%, #fff1f2 100%);
  border-color: #fecaca;
  color: #b91c1c;
}

.service-banner.status-device-state-missing,
.service-banner.status-device-not-ready {
  background: linear-gradient(135deg, #fff7ed 0%, #fffbeb 100%);
  border-color: #fed7aa;
  color: #9a3412;
}

.service-banner.status-checking {
  background: linear-gradient(135deg, #e0f2fe 0%, #eff6ff 100%);
  border-color: #bae6fd;
  color: #0369a1;
}

.list-item {
  padding: 22rpx 4rpx;
  border-bottom: 2rpx solid #eef2f7;
}

.list-item:last-child {
  border-bottom: none;
  padding-bottom: 2rpx;
}

.order-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.order-main {
  flex: 1;
  min-width: 0;
}

.order-side {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.order-row .status-badge {
  flex-shrink: 0;
  margin-top: 0;
}

.clear-order-btn,
.cancel-order-btn {
  width: auto;
  min-width: 88rpx;
  height: 46rpx;
  line-height: 46rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  color: #475569;
  font-size: 22rpx;
  font-weight: 800;
}

.clear-order-btn::after,
.cancel-order-btn::after {
  border: 2rpx solid #e2e8f0;
  border-radius: 999rpx;
}

.cancel-order-btn {
  background: #fff7ed;
  color: #c2410c;
}

.cancel-order-btn::after {
  border-color: #fed7aa;
}

.clear-order-btn[disabled],
.cancel-order-btn[disabled] {
  color: #94a3b8;
  background: #f1f5f9;
}

.item-title {
  color: #172033;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.35;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-subtitle,
.item-meta {
  color: #64748b;
  line-height: 1.5;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-alert {
  margin-top: 4rpx;
  color: #b91c1c;
}

.status-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.2;
  margin-top: 10rpx;
}

.status-created,
.status-pending_start {
  background: #dbeafe;
  color: #1d4ed8;
}

.status-delivering,
.status-tag_matched,
.status-acting {
  background: #fef3c7;
  color: #b45309;
}

.status-delivered {
  background: #dcfce7;
  color: #15803d;
}

.status-failed,
.status-cancelled {
  background: #fee2e2;
  color: #b91c1c;
}

.empty {
  color: #94a3b8;
  text-align: center;
  padding: 40rpx 8rpx 36rpx;
  line-height: 1.6;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 11rpx;
}

.empty-error {
  border-radius: 14rpx;
  background: #fff7ed;
  color: #9a3412;
}

.empty-mark {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #eef4ff;
}

.empty-mark::before,
.empty-mark::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.empty-mark-user::before {
  left: 18rpx;
  top: 14rpx;
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #2563eb;
  border-radius: 999rpx;
}

.empty-mark-user::after {
  left: 14rpx;
  bottom: 12rpx;
  width: 36rpx;
  height: 16rpx;
  border: 4rpx solid #2563eb;
  border-radius: 18rpx 18rpx 6rpx 6rpx;
  border-bottom: none;
}

.empty-mark-order::before,
.empty-mark-queue::before,
.empty-mark-active::before {
  left: 16rpx;
  top: 18rpx;
  width: 32rpx;
  height: 28rpx;
  border: 4rpx solid #2563eb;
  border-radius: 6rpx;
}

.empty-mark-order::after,
.empty-mark-queue::after,
.empty-mark-active::after {
  left: 24rpx;
  top: 28rpx;
  width: 16rpx;
  height: 4rpx;
  background: #2563eb;
  border-radius: 999rpx;
}

.empty-mark-active {
  background: #fff7ed;
}

.empty-mark-active::before {
  border-color: #d97706;
}

.empty-mark-active::after {
  background: #d97706;
}

.empty-mark-loading::before {
  left: 17rpx;
  top: 17rpx;
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid #93c5fd;
  border-left-color: #2563eb;
  border-radius: 999rpx;
}

.empty-title {
  color: #64748b;
  font-size: 25rpx;
  font-weight: 700;
}

.empty-copy {
  color: #94a3b8;
  font-size: 22rpx;
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.detail-main {
  flex: 1;
  min-width: 0;
}

.detail-head .section-title {
  margin-bottom: 12rpx;
}

.detail-head .status-badge {
  flex-shrink: 0;
  margin-top: 2rpx;
}

.detail-kicker {
  margin-bottom: 6rpx;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 700;
}

.detail-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.info-chip {
  max-width: 100%;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.flow {
  position: relative;
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
  margin: 20rpx 0 24rpx;
  padding: 24rpx 10rpx 22rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  overflow: hidden;
}

.flow::before {
  content: "";
  position: absolute;
  left: 52rpx;
  right: 52rpx;
  top: 47rpx;
  height: 2rpx;
  background: #dbe5f1;
}

.flow-step {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  text-align: center;
  color: #94a3b8;
}

.flow-dot {
  width: 46rpx;
  height: 46rpx;
  line-height: 46rpx;
  margin: 0 auto 9rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 800;
}

.flow-label {
  font-size: 22rpx;
  line-height: 1.2;
}

.flow-step-done,
.flow-step-active {
  color: #0f766e;
}

.flow-step-done .flow-dot,
.flow-step-active .flow-dot {
  background: #ccfbf1;
  color: #0f766e;
}

.flow-step-active .flow-dot {
  box-shadow: 0 0 0 6rpx rgba(15, 118, 110, 0.12);
}

.flow-step-stop {
  color: #b91c1c;
}

.flow-step-stop .flow-dot {
  background: #fee2e2;
  color: #b91c1c;
}

.detail-insights {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin: 0 0 18rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #f8fafc;
}

.insight-group-title {
  margin-bottom: 10rpx;
  color: #64748b;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.2;
}

.insight-chip-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 9rpx;
}

.insight-chip {
  min-width: 0;
  padding: 11rpx 8rpx;
  border-radius: 12rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  text-align: center;
}

.insight-ok {
  border-color: #bbf7d0;
  background: #f0fdf4;
}

.insight-warn {
  border-color: #fed7aa;
  background: #fff7ed;
}

.insight-muted {
  color: #94a3b8;
}

.insight-label,
.insight-value {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.insight-label {
  color: #64748b;
  font-size: 19rpx;
  font-weight: 800;
  line-height: 1.2;
}

.insight-value {
  margin-top: 6rpx;
  color: #172033;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.25;
}

.insight-ok .insight-value {
  color: #15803d;
}

.insight-warn .insight-value {
  color: #b45309;
}

.insight-muted .insight-value {
  color: #94a3b8;
}

.brief-lines {
  margin-top: 4rpx;
  padding: 6rpx 14rpx;
  border-radius: 14rpx;
  background: #f8fafc;
}

.brief-line {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 12rpx 0;
  border-bottom: 2rpx solid #eef2f7;
}

.brief-line:last-child {
  border-bottom: none;
}

.brief-key {
  flex-shrink: 0;
  color: #64748b;
}

.brief-value {
  min-width: 0;
  color: #172033;
  font-weight: 700;
  text-align: right;
  word-break: break-all;
}

.delivery-report {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  border: 1rpx solid #bbf7d0;
  background: linear-gradient(135deg, #f0fdf4 0%, #eff6ff 100%);
}

.report-failed,
.report-cancelled {
  border-color: #fecaca;
  background: linear-gradient(135deg, #fff7ed 0%, #fff1f2 100%);
}

.report-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.report-kicker {
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
}

.report-failed .report-kicker,
.report-cancelled .report-kicker {
  color: #b45309;
}

.report-title {
  margin-top: 6rpx;
  color: #172033;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.report-result {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #dcfce7;
  color: #15803d;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
}

.report-failed .report-result,
.report-cancelled .report-result {
  background: #fee2e2;
  color: #b91c1c;
}

.report-summary {
  color: #475569;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
  margin-bottom: 16rpx;
}

.report-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.report-action-row {
  margin-top: 16rpx;
}

.report-action-row .phone-btn {
  flex: 1;
  background: #ffffff;
  color: #1d4ed8;
}

.report-item {
  min-width: 0;
  padding: 14rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.72);
}

.report-label {
  color: #64748b;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.2;
}

.report-value {
  margin-top: 7rpx;
  color: #172033;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.3;
  word-break: break-all;
}

.timeline-item {
  position: relative;
  display: flex;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #eef2f7;
}

.timeline-item:last-child {
  border-bottom: none;
  padding-bottom: 2rpx;
}

.timeline-dot {
  flex-shrink: 0;
  width: 18rpx;
  height: 18rpx;
  margin-top: 9rpx;
  border-radius: 999rpx;
  background: #2563eb;
  box-shadow: 0 0 0 8rpx #eef4ff;
}

.timeline-main {
  flex: 1;
  min-width: 0;
}

.timeline-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.timeline-title {
  min-width: 0;
  color: #172033;
  font-size: 26rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.timeline-time {
  flex-shrink: 0;
  color: #94a3b8;
  font-size: 22rpx;
  font-weight: 700;
}

.timeline-detail {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.45;
  word-break: break-all;
}
