<view class="page app-page dispatch-page">
  <view class="hero page-hero dispatch-hero hero-card">
    <view class="hero-copy">
      <view class="title">调度台</view>
      <view class="hero-meta">配送调度 · {{lastRefreshText}}</view>
    </view>
    <view class="hero-stats">
      <view class="hero-stat">
        <view class="hero-stat-value">{{pendingOrders.length}}</view>
        <view class="hero-stat-label">待调度</view>
      </view>
      <view class="hero-stat hero-stat-warm">
        <view class="hero-stat-value">{{activeOrders.length}}</view>
        <view class="hero-stat-label">执行中</view>
      </view>
    </view>
    <view class="hero-actions">
      <button class="ghost-btn small-btn diagnostic-btn" bindtap="runPreflightCheck">自检</button>
      <button class="ghost-btn small-btn refresh-btn" loading="{{loading}}" bindtap="fetchOrders">刷新</button>
    </view>
  </view>

  <view class="service-banner status-{{serviceState}}">
    <view class="service-dot"></view>
    <view class="service-message">{{serviceMessage}}</view>
    <view class="service-detail-btn" bindtap="showServiceDiagnostics">诊断</view>
  </view>

  <view class="weather-strip">
    <block wx:for="{{weatherSummary.items}}" wx:key="key">
      <view class="weather-item weather-{{item.state}}">
        <view class="weather-label">{{item.label}}</view>
        <view class="weather-value">{{item.value}}</view>
      </view>
    </block>
  </view>

  <view class="voice-setting-row">
    <view class="voice-setting-copy">
      <view class="voice-setting-title">语音播报</view>
      <view class="voice-setting-subtitle">{{serviceVoiceEnabled ? '现场播报开启' : '调试静音中'}}</view>
    </view>
    <switch
      checked="{{serviceVoiceEnabled}}"
      disabled="{{voiceSwitchPending || !serviceOnline || !serviceMqttReady || !serviceDeviceStateReady}}"
      color="#10b981"
      bindchange="toggleVoice"
    />
  </view>

  <view class="card list-card">
    <view class="section-head">
      <view class="section-title">待调度</view>
      <view class="count-pill">{{pendingOrders.length}} 单</view>
    </view>
    <block wx:if="{{loadError}}">
      <view class="empty empty-error">{{loadError}}</view>
    </block>
    <block wx:elif="{{loading && !pendingOrders.length && !activeOrders.length}}">
      <view class="empty empty-state">
        <view class="empty-mark empty-mark-loading"></view>
        <view class="empty-title">加载中...</view>
      </view>
    </block>
    <block wx:elif="{{pendingOrders.length}}">
      <block wx:for="{{pendingOrders}}" wx:key="order_id">
        <view class="list-item order-row" data-order-id="{{item.order_id}}" bindtap="openDetail">
          <view class="order-main">
            <view class="item-title">{{item.order_name_text}}</view>
            <view class="item-subtitle">{{item.receiver_id}}</view>
          </view>
        </view>
      </block>
    </block>
    <view wx:else class="empty empty-state">
      <view class="empty-mark empty-mark-queue"></view>
      <view class="empty-title">暂无待调度</view>
      <view class="empty-copy">等待新的配送任务</view>
    </view>
  </view>

  <view class="card list-card">
    <view class="section-head">
      <view class="section-title">执行中</view>
      <view class="count-pill">{{activeOrders.length}} 单</view>
    </view>
    <block wx:if="{{loadError}}">
      <view class="empty empty-error">{{loadError}}</view>
    </block>
    <block wx:elif="{{activeOrders.length}}">
      <block wx:for="{{activeOrders}}" wx:key="order_id">
        <view class="list-item order-row" data-order-id="{{item.order_id}}" bindtap="openDetail">
          <view class="order-main">
            <view class="item-title">{{item.order_name_text}}</view>
            <view class="item-subtitle">{{item.receiver_id}} · Tag {{item.apriltag_text}}</view>
          </view>
          <view class="status-badge status-{{item.status}}">{{item.status_text}}</view>
        </view>
      </block>
    </block>
    <view wx:else class="empty empty-state">
      <view class="empty-mark empty-mark-active"></view>
      <view class="empty-title">暂无执行中</view>
      <view class="empty-copy">当前没有正在执行的任务</view>
    </view>
  </view>

  <view class="page-footnote">
    <view class="page-footnote-team">地线引力队</view>
    <view>第九届（2026）全国大学生嵌入式芯片与系统设计竞赛</view>
  </view>
</view>
