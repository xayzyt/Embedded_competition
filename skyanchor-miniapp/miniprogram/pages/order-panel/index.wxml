<view class="page">
  <view class="hero">
    <view class="title">订单详情</view>
    <view class="subtitle">{{isReceiverView ? '这里显示当前订单状态，以及配送端为你分配的 AprilTag 号。' : '这里显示当前订单状态。配送端先手动选择 AprilTag 0 或 1，再开始配送；板端会收到对应目标号。'}}</view>
  </view>

  <view class="service-banner status-{{serviceState}}">
    {{serviceMessage}}
  </view>

  <view class="card" wx:if="{{loadError}}">
    <view class="section-title">订单状态</view>
    <view class="empty">{{loadError}}</view>
    <view class="button-row">
      <button class="primary-btn" loading="{{loading}}" bindtap="fetchDetail">重新加载</button>
    </view>
  </view>

  <view class="card" wx:elif="{{loading && !order}}">
    <view class="section-title">订单状态</view>
    <view class="empty">正在加载订单详情...</view>
  </view>

  <view class="card" wx:elif="{{order}}">
    <view class="section-title">{{order.order_id}}</view>
    <view class="section-caption">{{isReceiverView ? '你可以在这里查看订单状态变化。' : '配送端可在这里完成 AprilTag 选择、开始配送和取消订单。'}}</view>

    <view class="kv">
      <text class="kv-key">状态</text>
      <text class="kv-value">{{order.status_text}}</text>
    </view>
    <view class="kv" wx:if="{{order.note_text}}">
      <text class="kv-key">{{order.note_label}}</text>
      <text class="kv-value">{{order.note_text}}</text>
    </view>
    <view class="kv" wx:if="{{order.last_device_state_text}}">
      <text class="kv-key">板端状态</text>
      <text class="kv-value">{{order.last_device_state_text}}</text>
    </view>
    <view class="kv">
      <text class="kv-key">AprilTag号</text>
      <text class="kv-value">{{order.apriltag_text}}</text>
    </view>
    <view class="kv">
      <text class="kv-key">用户 ID</text>
      <text class="kv-value">{{order.receiver_id}}</text>
    </view>

    <view class="button-row detail-action-row {{isReceiverView ? 'single-action-row' : ''}}">
      <button class="ghost-btn" loading="{{loading}}" disabled="{{actionPending}}" bindtap="fetchDetail">刷新</button>
      <button
        wx:if="{{!isReceiverView}}"
        class="primary-btn"
        loading="{{actionPending && !loading}}"
        disabled="{{loading || actionPending || order.primary_action_disabled || (serviceWeatherBlocked && order.primary_action == 'start')}}"
        bindtap="handlePrimaryAction"
      >
        {{order.primary_action_text}}
      </button>
      <button
        wx:if="{{!isReceiverView}}"
        class="warn-btn"
        disabled="{{loading || actionPending || !order.can_cancel}}"
        bindtap="cancelOrder"
      >
        取消订单
      </button>
    </view>
  </view>

  <view class="page-footnote">
    <view>第九届（2026）全国大学生嵌入式芯片与系统设计竞赛</view>
    <view class="page-footnote-team">地线引力队</view>
  </view>
</view>
