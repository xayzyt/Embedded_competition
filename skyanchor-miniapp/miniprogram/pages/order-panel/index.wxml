<view class="page app-page order-detail-page">
  <view class="service-banner status-{{serviceState}}" bindtap="showServiceDiagnostics">
    <view class="service-dot"></view>
    <view class="service-message">{{serviceMessage}}</view>
  </view>

  <view class="card" wx:if="{{loadError}}">
    <view class="section-title">订单状态</view>
    <view class="empty empty-error">{{loadError}}</view>
    <view class="button-row">
      <button class="primary-btn" loading="{{loading}}" bindtap="fetchDetail">重试</button>
    </view>
  </view>

  <view class="card" wx:elif="{{loading && !order}}">
    <view class="section-title">订单状态</view>
    <view class="empty empty-state">
      <view class="empty-mark empty-mark-loading"></view>
      <view class="empty-title">加载中...</view>
    </view>
  </view>

  <view class="card order-sheet" wx:elif="{{order}}">
    <view class="detail-head">
      <view class="detail-main">
        <view class="section-title">{{order.order_name_text}}</view>
        <view class="detail-meta-line">
          <text wx:if="{{!isReceiverView}}">用户 {{order.receiver_id}}</text>
          <text>Tag {{order.apriltag_text}}</text>
          <text wx:if="{{order.last_device_state_text}}">板端 {{order.last_device_state_text}}</text>
        </view>
      </view>
      <view class="status-badge status-{{order.status}}">{{order.status_text}}</view>
    </view>

    <view class="flow">
      <block wx:for="{{order.flow_steps}}" wx:key="key">
        <view class="flow-step flow-step-{{item.state}}">
          <view class="flow-dot">{{item.num}}</view>
          <view class="flow-label">{{item.label}}</view>
        </view>
      </block>
    </view>

    <view class="weather-strip weather-strip-detail">
      <block wx:for="{{runtimeSummary.items}}" wx:key="key">
        <view class="weather-item weather-{{item.state}}">
          <text class="weather-label">{{item.label}}</text>
          <text class="weather-value">{{item.value}}</text>
        </view>
      </block>
    </view>

    <view class="failure-card failure-{{order.issue.level}}" wx:if="{{order.issue.show}}">
      <view class="failure-title">原因：{{order.failure_reason_text}}</view>
      <view class="failure-advice">建议：{{order.failure_advice_text}}</view>
    </view>

    <view class="delivery-report report-{{order.report.class_name}}" wx:if="{{order.show_report}}">
      <view class="report-hero">
        <view class="report-mark">{{order.report.result_text}}</view>
        <view class="report-copy">
          <view class="report-title">{{order.report.title}}</view>
          <view class="report-summary">{{order.report.summary_text}}</view>
        </view>
      </view>
      <view class="report-grid">
        <view class="report-item">
          <view class="report-label">Tag</view>
          <view class="report-value">{{order.report.tag_text}}</view>
        </view>
        <view class="report-item">
          <view class="report-label">耗时</view>
          <view class="report-value">{{order.report.duration_text}}</view>
        </view>
        <view class="report-item">
          <view class="report-label">结束</view>
          <view class="report-value">{{order.report.finished_text}}</view>
        </view>
        <view class="report-item">
          <view class="report-label">状态</view>
          <view class="report-value">{{order.report.device_text}}</view>
        </view>
      </view>
      <view class="delivery-photo-entry" wx:if="{{order.delivery_photo_visible}}" bindtap="previewDeliveryPhoto">
        <view class="delivery-photo-copy">
          <view class="delivery-photo-title">送达照片</view>
          <view class="delivery-photo-desc">{{order.delivery_photo_ready ? '点击查看接货画面' : order.delivery_photo_text}}</view>
        </view>
        <view class="delivery-photo-action {{order.delivery_photo_ready ? 'ready' : 'pending'}}">{{order.delivery_photo_text}}</view>
      </view>
      <view class="button-row report-action-row" wx:if="{{isReceiverView && order.show_contact_dispatcher}}">
        <button class="ghost-btn phone-btn" bindtap="contactDispatcher">联系配送员</button>
      </view>
    </view>

    <view class="button-row detail-action-row {{isReceiverView || (order.primary_action_disabled && !order.can_demo_reset) ? 'single-action-row' : ''}}">
      <button class="ghost-btn refresh-btn" loading="{{loading}}" disabled="{{actionPending}}" bindtap="fetchDetail">刷新</button>
      <button
        wx:if="{{!isReceiverView && !order.primary_action_disabled}}"
        class="primary-btn"
        loading="{{actionPending && !loading}}"
        disabled="{{loading || actionPending || (serviceActionBlocked && order.primary_action == 'start')}}"
        bindtap="handlePrimaryAction"
      >
        {{order.primary_action_text}}
      </button>
      <button
        wx:if="{{!isReceiverView && order.can_cancel}}"
        class="warn-btn"
        disabled="{{loading || actionPending || !order.can_cancel}}"
        bindtap="cancelOrder"
      >
        取消
      </button>
      <button
        wx:if="{{!isReceiverView && order.can_demo_reset}}"
        class="warn-btn reset-btn"
        loading="{{actionPending && !loading}}"
        disabled="{{loading || actionPending || !order.can_demo_reset}}"
        bindtap="demoResetOrder"
      >
        演示复位
      </button>
    </view>

    <view class="button-row manual-action-row" wx:if="{{order.can_manual_retract}}">
      <button
        class="safe-btn"
        loading="{{actionPending && !loading}}"
        disabled="{{loading || actionPending || !order.can_manual_retract}}"
        bindtap="manualRetractTray"
      >
        回收托盘
      </button>
    </view>
  </view>

  <view class="timeline-card" wx:if="{{events.length}}">
    <view class="section-head">
      <view class="section-title">记录</view>
      <view class="count-pill">{{events.length}}</view>
    </view>
    <block wx:for="{{events}}" wx:key="id">
      <view class="timeline-item">
        <view class="timeline-dot"></view>
        <view class="timeline-main">
          <view class="timeline-head">
            <view class="timeline-title">{{item.title_text}}</view>
            <view class="timeline-time">{{item.time_text}}</view>
          </view>
          <view class="timeline-detail" wx:if="{{item.detail_text}}">{{item.detail_text}}</view>
        </view>
      </view>
    </block>
  </view>

  <view class="report-modal-mask" wx:if="{{showDeliveryReportModal}}" catchtap="closeDeliveryReport">
    <view class="report-modal" catchtap="noop">
      <view class="modal-report-mark">{{deliveryReportModal.result_text}}</view>
      <view class="modal-report-title">配送报告</view>
      <view class="modal-order-name">{{deliveryReportModal.order_name_text}}</view>
      <view class="modal-report-grid">
        <view class="modal-report-item">
          <text class="modal-report-label">Tag</text>
          <text class="modal-report-value">{{deliveryReportModal.tag_text}}</text>
        </view>
        <view class="modal-report-item">
          <text class="modal-report-label">耗时</text>
          <text class="modal-report-value">{{deliveryReportModal.duration_text}}</text>
        </view>
        <view class="modal-report-item">
          <text class="modal-report-label">结束</text>
          <text class="modal-report-value">{{deliveryReportModal.finished_text}}</text>
        </view>
        <view class="modal-report-item">
          <text class="modal-report-label">状态</text>
          <text class="modal-report-value">{{deliveryReportModal.device_text}}</text>
        </view>
      </view>
      <view class="modal-actions">
        <button
          wx:if="{{deliveryReportModal.photo_file_id}}"
          class="ghost-btn modal-btn"
          bindtap="previewDeliveryPhoto"
        >
          送达照片
        </button>
        <button
          wx:if="{{deliveryReportModal.can_contact_dispatcher}}"
          class="ghost-btn modal-btn"
          bindtap="contactDispatcher"
        >
          联系配送员
        </button>
        <button class="primary-btn modal-btn" bindtap="closeDeliveryReport">知道了</button>
      </view>
    </view>
  </view>
</view>
