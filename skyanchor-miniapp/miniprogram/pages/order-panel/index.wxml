<view class="page app-page order-detail-page">
  <view class="hero page-hero hero-card">
    <view class="title">订单详情</view>
    <view class="hero-meta">{{isReceiverView ? '用户端视图' : '调度台视图'}}</view>
  </view>

  <view class="service-banner status-{{serviceState}}">
    <view class="service-dot"></view>
    <view class="service-message">{{serviceMessage}}</view>
    <view class="service-detail-btn" bindtap="showServiceDiagnostics">诊断</view>
  </view>

  <view class="card" wx:if="{{loadError}}">
    <view class="section-title">订单状态</view>
    <view class="empty empty-error">{{loadError}}</view>
    <view class="button-row">
      <button class="primary-btn" loading="{{loading}}" bindtap="fetchDetail">重试</button>
    </view>
  </view>

  <view class="card" wx:elif="{{loading && !order}}">
    <view class="section-title">订单状态</view>
    <view class="empty empty-state">
      <view class="empty-mark empty-mark-loading"></view>
      <view class="empty-title">加载中...</view>
    </view>
  </view>

  <view class="card" wx:elif="{{order}}">
    <view class="detail-head">
      <view class="detail-main">
        <view class="detail-kicker">订单编号</view>
        <view class="section-title">{{order.order_name_text}}</view>
        <view class="detail-chip-row">
          <view class="info-chip" wx:if="{{!isReceiverView}}">用户 {{order.receiver_id}}</view>
          <view class="info-chip">Tag {{order.apriltag_text}}</view>
        </view>
      </view>
      <view class="status-badge status-{{order.status}}">{{order.status_text}}</view>
    </view>

    <view class="flow">
      <block wx:for="{{order.flow_steps}}" wx:key="key">
        <view class="flow-step flow-step-{{item.state}}">
          <view class="flow-dot">{{item.num}}</view>
          <view class="flow-label">{{item.label}}</view>
        </view>
      </block>
    </view>

    <view class="detail-insights">
      <view class="insight-group">
        <view class="insight-group-title">链路状态</view>
        <view class="insight-chip-row">
          <block wx:for="{{detailStatusTiles}}" wx:key="key">
            <view class="insight-chip insight-{{item.state}}">
              <text class="insight-label">{{item.label}}</text>
              <text class="insight-value">{{item.value}}</text>
            </view>
          </block>
        </view>
      </view>
      <view class="insight-group">
        <view class="insight-group-title">安全策略</view>
        <view class="insight-chip-row">
          <block wx:for="{{safetyBadges}}" wx:key="key">
            <view class="insight-chip insight-{{item.state}}">
              <text class="insight-label">{{item.label}}</text>
              <text class="insight-value">{{item.value}}</text>
            </view>
          </block>
        </view>
      </view>
    </view>

    <view class="brief-lines" wx:if="{{order.note_text || order.last_device_state_text}}">
      <view class="brief-line" wx:if="{{order.note_text}}">
        <text class="brief-key">{{order.note_label}}</text>
        <text class="brief-value">{{order.note_text}}</text>
      </view>
      <view class="brief-line" wx:if="{{order.last_device_state_text}}">
        <text class="brief-key">板端</text>
        <text class="brief-value">{{order.last_device_state_text}}</text>
      </view>
    </view>

    <view class="delivery-report report-{{order.report.class_name}}" wx:if="{{order.show_report}}">
      <view class="report-head">
        <view>
          <view class="report-kicker">智能配送闭环</view>
          <view class="report-title">{{order.report.title}}</view>
        </view>
        <view class="report-result">{{order.report.result_text}}</view>
      </view>
      <view class="report-summary">{{order.report.summary_text}}</view>
      <view class="report-grid">
        <view class="report-item">
          <view class="report-label">目标 Tag</view>
          <view class="report-value">{{order.report.tag_text}}</view>
        </view>
        <view class="report-item">
          <view class="report-label">总耗时</view>
          <view class="report-value">{{order.report.duration_text}}</view>
        </view>
        <view class="report-item">
          <view class="report-label">板端状态</view>
          <view class="report-value">{{order.report.device_text}}</view>
        </view>
        <view class="report-item">
          <view class="report-label">说明</view>
          <view class="report-value">{{order.report.note_text}}</view>
        </view>
      </view>
      <view class="button-row report-action-row" wx:if="{{isReceiverView && order.show_contact_dispatcher}}">
        <button class="ghost-btn phone-btn" bindtap="contactDispatcher">联系配送员</button>
      </view>
    </view>

    <view class="button-row detail-action-row {{isReceiverView ? 'single-action-row' : ''}}">
      <button class="ghost-btn refresh-btn" loading="{{loading}}" disabled="{{actionPending}}" bindtap="fetchDetail">刷新</button>
      <button
        wx:if="{{!isReceiverView}}"
        class="primary-btn"
        loading="{{actionPending && !loading}}"
        disabled="{{loading || actionPending || order.primary_action_disabled || (serviceActionBlocked && order.primary_action == 'start')}}"
        bindtap="handlePrimaryAction"
      >
        {{order.primary_action_text}}
      </button>
      <button
        wx:if="{{!isReceiverView}}"
        class="warn-btn"
        disabled="{{loading || actionPending || !order.can_cancel}}"
        bindtap="cancelOrder"
      >
        取消
      </button>
    </view>

    <view class="button-row manual-action-row" wx:if="{{order.can_manual_retract}}">
      <button
        class="safe-btn"
        loading="{{actionPending && !loading}}"
        disabled="{{loading || actionPending || !order.can_manual_retract}}"
        bindtap="manualRetractTray"
      >
        手动回收托盘
      </button>
    </view>
  </view>

  <view class="card" wx:if="{{events.length}}">
    <view class="section-head">
      <view class="section-title">智能配送时间线</view>
      <view class="count-pill">{{events.length}} 条</view>
    </view>
    <block wx:for="{{events}}" wx:key="id">
      <view class="timeline-item">
        <view class="timeline-dot"></view>
        <view class="timeline-main">
          <view class="timeline-head">
            <view class="timeline-title">{{item.title_text}}</view>
            <view class="timeline-time">{{item.time_text}}</view>
          </view>
          <view class="timeline-detail" wx:if="{{item.detail_text}}">{{item.detail_text}}</view>
        </view>
      </view>
    </block>
  </view>

  <view class="page-footnote">
    <view class="page-footnote-team">地线引力队</view>
    <view>第九届（2026）全国大学生嵌入式芯片与系统设计竞赛</view>
  </view>
</view>
