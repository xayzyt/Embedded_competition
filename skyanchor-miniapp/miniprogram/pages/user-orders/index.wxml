<view class="page app-page user-page">
  <view class="hero hero-line page-hero hero-card">
    <view class="hero-copy">
      <view class="title">用户端</view>
      <view class="hero-meta">{{receiverId ? receiverId : '未设置 ID'}}</view>
    </view>
    <view class="hero-actions">
      <view class="hero-stat">
        <view class="hero-stat-value">{{orders.length}}</view>
        <view class="hero-stat-label">订单</view>
      </view>
      <button class="ghost-btn small-btn refresh-btn" loading="{{loading}}" bindtap="fetchOrders">刷新</button>
    </view>
  </view>

  <view class="service-banner status-{{serviceState}}">
    <view class="service-dot"></view>
    <view class="service-message">{{serviceMessage}}</view>
    <view class="service-detail-btn" bindtap="showServiceDiagnostics">诊断</view>
  </view>

  <view class="card profile-card">
    <view class="section-head">
      <view class="section-title">用户信息</view>
      <view class="count-pill">ID</view>
    </view>
    <view class="field">
      <text class="field-label">用户 ID</text>
      <input class="input" value="{{receiverId}}" placeholder="receiver" bindinput="handleInput" />
    </view>

    <view class="button-row compact">
      <button class="ghost-btn" bindtap="saveReceiver">保存</button>
      <button class="primary-btn" loading="{{creating}}" disabled="{{serviceActionBlocked}}" bindtap="openCreateOrder">提交订单</button>
    </view>
  </view>

  <view class="card list-card">
    <view class="section-head">
      <view class="section-title">我的订单</view>
      <view class="count-pill">{{orders.length}} 单</view>
    </view>
    <block wx:if="{{loadError}}">
      <view class="empty empty-error">{{loadError}}</view>
    </block>
    <block wx:elif="{{!receiverId}}">
      <view class="empty empty-state">
        <view class="empty-mark empty-mark-user"></view>
        <view class="empty-title">先保存用户 ID</view>
      </view>
    </block>
    <block wx:elif="{{loading && !orders.length}}">
      <view class="empty empty-state">
        <view class="empty-mark empty-mark-loading"></view>
        <view class="empty-title">加载中...</view>
      </view>
    </block>
    <block wx:elif="{{orders.length}}">
      <block wx:for="{{orders}}" wx:key="order_id">
        <view class="list-item order-row" data-order-id="{{item.order_id}}" bindtap="openOrder">
          <view class="order-main">
            <view class="item-title">{{item.order_name_text}}</view>
            <view class="item-subtitle">Tag {{item.apriltag_text}}</view>
            <view class="item-meta item-alert" wx:if="{{item.is_failed && item.note_text}}">失败原因：{{item.note_text}}</view>
          </view>
          <view class="order-side">
            <view class="status-badge status-{{item.status}}">{{item.status_text}}</view>
            <button
              wx:if="{{item.can_cancel}}"
              class="cancel-order-btn"
              loading="{{cancellingOrderId == item.order_id}}"
              disabled="{{cancellingOrderId || clearingOrderId}}"
              data-order-id="{{item.order_id}}"
              data-order-name="{{item.order_name_text}}"
              catchtap="cancelOrder"
            >取消</button>
            <button
              wx:if="{{item.can_clear}}"
              class="clear-order-btn"
              loading="{{clearingOrderId == item.order_id}}"
              disabled="{{clearingOrderId || cancellingOrderId}}"
              data-order-id="{{item.order_id}}"
              data-order-name="{{item.order_name_text}}"
              catchtap="clearOrder"
            >清除</button>
          </view>
        </view>
      </block>
    </block>
    <view wx:else class="empty empty-state">
      <view class="empty-mark empty-mark-order"></view>
      <view class="empty-title">暂无订单</view>
      <view class="empty-copy">等待新的配送任务</view>
    </view>
  </view>

  <view class="page-footnote">
    <view class="page-footnote-team">地线引力队</view>
    <view>第九届（2026）全国大学生嵌入式芯片与系统设计竞赛</view>
  </view>
</view>
